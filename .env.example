# ═══════════════════════════════════════════════════════════════
# iSafe CRM — Arquivo de Configuração
#
# COMO USAR:
#   1. Copie este arquivo:  cp .env.example .env
#   2. Preencha cada valor com seus dados reais
#   3. NUNCA suba o arquivo .env para o GitHub (já protegido no .gitignore)
#
# Para gerar valores aleatórios seguros (WEBHOOK_SECRET, JWT_SECRET, API_KEY):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ═══════════════════════════════════════════════════════════════

# ── AMBIENTE ──────────────────────────────────────────────────────
# "production" no servidor real | "development" na sua máquina local
NODE_ENV=production

# ── BANCO DE DADOS ────────────────────────────────────────────────
# Senha do PostgreSQL — use algo difícil de adivinhar
DB_PASSWORD=troque_por_uma_senha_forte_aqui

# ── ACESSO AO PAINEL (LOGIN) ──────────────────────────────────────
# Usuário e senha para entrar no dashboard
ADMIN_USER=admin
ADMIN_PASSWORD=troque_por_uma_senha_forte_aqui

# Segredo para assinar os tokens JWT — gere um valor aleatório:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# Tempo de validade do token de login (ex: 8h, 24h, 7d)
JWT_EXPIRY=8h

# ── BLING API ─────────────────────────────────────────────────────
# Onde encontrar: bling.com.br → Configurações → API → Criar App
# Após preencher aqui, clique em "Conectar ao Bling" no painel
BLING_CLIENT_ID=cole_seu_client_id_aqui
BLING_CLIENT_SECRET=cole_seu_client_secret_aqui

# Gerados automaticamente pelo sistema após autorizar — não preencha manualmente
BLING_ACCESS_TOKEN=
BLING_REFRESH_TOKEN=

# URL pública do seu servidor (onde o Bling enviará callbacks e webhooks)
APP_URL=https://crm.lojaisafe.com.br

# ── WHATSAPP (Evolution API) ──────────────────────────────────────
# Configure no painel: Configurações → WhatsApp
EVOLUTION_API_URL=https://api.lojaisafe.com.br
EVOLUTION_API_KEY=cole_sua_chave_evolution_aqui
EVOLUTION_INSTANCE=isafe-principal

# ── EMAIL (SendGrid) ──────────────────────────────────────────────
# Onde obter: app.sendgrid.com → Settings → API Keys
# Configure no painel: Configurações → E-mail
SENDGRID_API_KEY=SG.cole_sua_chave_sendgrid_aqui
EMAIL_FROM=contato@lojaisafe.com.br
EMAIL_FROM_NAME=iSafe

# ── SEGURANÇA WEBHOOK ─────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=cole_o_valor_gerado_aqui

# x-api-key para scripts externos e integração com outros sistemas
API_KEY=cole_outro_valor_gerado_aqui

# ── AGENDAMENTO ───────────────────────────────────────────────────
# Horário em que o scheduler dispara as automações (formato cron)
# "0 9 * * *" = todo dia às 9h da manhã
SCHEDULER_CRON=0 9 * * *
SCHEDULER_TOLERANCE_DAYS=1

# ── SHOPIFY (opcional — só preencha se usar Shopify) ──────────────
SHOPIFY_STORE=lojaisafe.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ── BAGY (opcional — só preencha se usar Bagy) ────────────────────
BAGY_API_KEY=
BAGY_STORE_ID=
